</footer>

<!-- page navigation script -->
<script>
  (function() {
    // get all nav links (both header and footer quick links)
    const navLinks = document.querySelectorAll('.nav-links a, .footer-grid a[data-page]');
    const sections = {
      home: document.getElementById('home'),
      about: document.getElementById('about'),
      contact: document.getElementById('contact'),
      privacy: document.getElementById('privacy'),
      terms: document.getElementById('terms')
    };

    function activatePage(pageId) {
      // hide all sections
      Object.values(sections).forEach(section => section.classList.remove('active'));
      // show selected
      if (sections[pageId]) sections[pageId].classList.add('active');
      // update nav active class
      document.querySelectorAll('.nav-links a').forEach(link => {
        link.classList.remove('active');
        if (link.dataset.page === pageId) link.classList.add('active');
      });
      // scroll to top
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // event listeners
    navLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const page = this.dataset.page;
        if (page && sections[page]) {
          activatePage(page);
        } else {
          // if no page (footer quick links) fallback
          const fallback = this.getAttribute('data-page');
          if (fallback && sections[fallback]) activatePage(fallback);
        }
      });
    });

    // set home active by default (already active in html)
    // if any link with active class from html, ensure home is active
    const activeLink = document.querySelector('.nav-links a.active');
    if (activeLink) {
      const page = activeLink.dataset.page;
      if (page && sections[page]) {
        Object.values(sections).forEach(s => s.classList.remove('active'));
        sections[page].classList.add('active');
      }
    } else {
      // fallback
      activatePage('home');
    }
  })();
</script>

