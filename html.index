      <div>
        <h4>Contact</h4>
        <p><i class="fas fa-phone" style="color:#fbbf24;"></i> 9022216667</p>
        <p><i class="fas fa-envelope" style="color:#fbbf24;"></i> anvirealtorsdata@gmail.com</p>
        <p><i class="fas fa-map-pin" style="color:#fbbf24;"></i> Diva East, Maharashtra 400612</p>
      </div>
      <div>
        <h4>Follow</h4>
        <div class="social">
          <i class="fab fa-facebook"></i>
          <i class="fab fa-instagram"></i>
          <i class="fab fa-youtube"></i>
          <i class="fab fa-linkedin"></i>
        </div>
      </div>
    </div>
    <div class="copy">
      &copy; 2026 <span>ANVI REALTORS</span> · All rights reserved. Real Estate Excellence.
    </div>
